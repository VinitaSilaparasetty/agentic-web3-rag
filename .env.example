# File: .env.example
# Why: Make Phase-1 constraints explicit; default to strict allowlist-only ingestion.
APP_ENV=local
APP_PHASE=alpha
POLICY_MODE=allowlist_only

API_HOST=0.0.0.0
API_PORT=8080
JWT_SECRET=dev-secret-change-me
JWT_ALG=HS256

OPENAI_API_KEY=your-openai-api-key-here
GITHUB_TOKEN=your-github-personal-access-token-here

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_STAGING=web3_docs_staging
QDRANT_ALIAS_ACTIVE=web3_docs_active

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/web3rag

EMBEDDING_MODEL=BAAI/bge-m3
USER_AGENT=agentic-web3-rag/0.1 (+https://github.com/you/agentic-web3-rag)
CACHE_POLICY_DEFAULT=link-only
SNIPPET_CHARS=240
RESPECT_ROBOTS=true
DENYLIST=example.com,badsite.io
